{
  "name": "zx-angular-lazy-resource",
  "version": "0.1.0",
  "description": "Lazy helpers for Angular's signal-based resource(): defer loading until first access, and await the first settled value as a Promise.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "angular",
    "signals",
    "resource",
    "lazy",
    "lazy-loading",
    "deferred",
    "async",
    "await",
    "httpResource",
    "ngx"
  ],
  "author": "zxnc",
  "license": "MIT",
  "homepage": "https://github.com/zxnc/zx-angular-lazy-resource#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zxnc/zx-angular-lazy-resource.git"
  },
  "bugs": {
    "url": "https://github.com/zxnc/zx-angular-lazy-resource/issues"
  },
  "peerDependencies": {
    "@angular/core": ">=19.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/core": "^20.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~5.6.0"
  }
}
